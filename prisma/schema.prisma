generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Laptop {
  id          String  @id @db.VarChar(30)
  nama        String
  merek       String  @db.VarChar(50)
  harga       Int
  kondisi     String  @db.VarChar(20)
  spesifikasi String?
  kategori    String?
  rating      Float?
  sumber      String?
}
